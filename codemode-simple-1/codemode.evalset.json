{
  "name": "context-engineering-codemode",
  "description": "MCP tools + skills with codemode enabled.",
  "run_environment": "sdk",
  "kind": "batch",
  "tags": ["context-engineering", "codemode", "github-actions"],
  "metadata": {
    "scenario": "agentic-data-analysis",
    "codemode_enabled": true,
    "comparison_group": "secondary"
  },
  "schema": {
    "schema_version": "1.0",
    "kind": "batch",
    "input_schema": {
      "type": "object",
      "required": ["prompt"],
      "properties": {
        "prompt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "text": { "type": "string" }
      },
      "additionalProperties": true
    },
    "metadata_schema": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "cases": [
    {
      "name": "kpi-summary",
      "inputs": { "prompt": "Summarize monthly ARR trend and top risk in one paragraph." },
      "expected_output": { "text": "Mentions ARR trend and one top risk." },
      "metadata": { "domain": "finance" }
    },
    {
      "name": "sql-safety",
      "inputs": { "prompt": "Write a SQL query for top 5 customers by revenue in 2025." },
      "expected_output": { "text": "Includes SELECT and GROUP BY with sane filtering." },
      "metadata": { "domain": "analytics" }
    }
  ]
}